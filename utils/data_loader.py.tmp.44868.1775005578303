@st.cache_data(ttl=300)
def get_base_date():
    source = get_excel_data()
    if not source:
        return None
    try:
        df = pd.read_excel(source, sheet_name='일일입력', nrows=2, header=None)
        val = df.iloc[1, 1]
        try:
            return pd.to_datetime(str(int(val)), format='%Y%m%d')
        except:
            return val
    except Exception:
        return None


